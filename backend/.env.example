
# ==========================================
#      Backend Environment Variables
# ==========================================

# --------------------------
# Application Mode
# --------------------------

# If true, runs the backend in CLI mode (no server)
CLI_MODE=false

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO


# --------------------------
# Google Gemini API
# --------------------------

# API key for Google Gemini integration
GOOGLE_API_KEY=your_google_api_key_here


# --------------------------
# Server Configuration
# --------------------------

# Host address where the backend server will run
HOST=0.0.0.0

# Port exposed by the backend server
PORT=8080


# --------------------------
# Database Configuration
# --------------------------

# Database connection string
# Example (PostgreSQL):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/dbname
DATABASE_URL=your_database_url_here


# --------------------------
# Playwright Configuration
# --------------------------

# Run browser in headless mode (true/false)
HEADLESS=false


# --------------------------
# Security
# --------------------------

# Secret key used for signing tokens or session data
SECRET_KEY=your_secret_key_here